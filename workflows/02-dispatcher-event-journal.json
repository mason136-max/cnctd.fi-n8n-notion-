      ],
      "parameters": {
        "jsCode": "if(($json.results||[]).length)return[];const s=$('Подготовить снимки').item.json;const rt=v=>[{type:'text',text:{content:String(v)}}];const properties={'Событие':{title:rt(s.event)},'Дата снимка':{date:{start:s.snapshotDate}},'Неделя':{rich_text:rt(s.week)},'День':{select:{name:s.weekday}},'Категории':{multi_select:s.categories.map(name=>({name}))},'Открытых задач':{number:s.open},'Срочных задач':{number:s.urgent},'Просроченных':{number:s.overdue},'Индекс нагрузки':{number:s.index},'Уровень нагрузки':{select:{name:s.level}},'Шкала нагрузки':{rich_text:rt(s.bar)},'Сводка':{rich_text:rt(s.summary)},'ID запуска':{rich_text:rt(s.execution)},'Ключ снимка':{rich_text:rt(s.key)},'Источник':{url:s.source},'Ближайший дедлайн':{date:s.nearest?{start:s.nearest}:null}};return[{json:{parent:{database_id:'daa0be3f-59ce-4761-8625-43419d47c7d7'},properties}}]"
