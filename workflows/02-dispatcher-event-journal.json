      "parameters": {
        "jsCode": "const rows=$json.results||[];const now=new Date();const day=now.toISOString().slice(0,10);const d=new Date(now);const wd=(d.getDay()+6)%7;d.setDate(d.getDate()-wd);const week=d.toISOString().slice(0,10);const text=p=>p?.rich_text?.map(x=>x.plain_text).join('')||'';const title=p=>p?.title?.map(x=>x.plain_text).join('')||'';return rows.map(r=>{const p=r.properties;const weekday=title(p['День']);return{json:{snapshotDate:now.toISOString(),week,weekday,key:day+'|'+weekday,event:'Снимок '+day+' — '+weekday,categories:(p['Категории']?.multi_select||[]).map(x=>x.name),open:p['Открытых задач']?.number||0,urgent:p['Срочных задач']?.number||0,overdue:p['Просроченных']?.number||0,index:p['Индекс нагрузки']?.number||0,level:p['Уровень нагрузки']?.select?.name||'🟢 Низкая',bar:text(p['Шкала нагрузки']),nearest:p['Ближайший дедлайн']?.date?.start||null,summary:text(p['Сводка']),source:r.url,execution:String($execution.id)}}})"
      }
    },
