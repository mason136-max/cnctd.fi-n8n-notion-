    {
      "id": "payload",
      "name": "Подготовить upsert",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1290,
        0
      ],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const plan=$('Рассчитать и распределить').all()[$itemIndex].json;const raw=$json;const bytes=(raw?._readableState?.buffer||[]).flatMap(x=>x?.data||[]);const response=raw?.results?raw:bytes.length?JSON.parse(new TextDecoder().decode(Uint8Array.from(bytes))):typeof raw?.body==='string'?JSON.parse(raw.body):raw?.body||raw;const existing=response.results?.[0]?.id;const rich=v=>[{type:'text',text:{content:String(v)}}];const properties={'День':{title:rich(plan.day)},'Порядок':{number:plan.order},'Активная':{checkbox:true},'Категории':{multi_select:plan.categories.map(name=>({name}))},'Индекс нагрузки':{number:plan.index},'Уровень нагрузки':{select:{name:plan.level}},'Шкала нагрузки':{rich_text:rich(plan.bar)},'Открытых задач':{number:plan.open},'Срочных задач':{number:plan.urgent},'Просроченных':{number:plan.overdue},'Сводка':{rich_text:rich(plan.summary)},'Последнее обновление':{date:{start:plan.updated}},'Ближайший дедлайн':{date:plan.nearest?{start:plan.nearest}:null}};return {json:{method:existing?'PATCH':'POST',url:existing?'https://api.notion.com/v1/pages/'+existing:'https://api.notion.com/v1/pages',body:existing?{properties}:{parent:{database_id:'5c523f23-df7a-4a2f-b5f3-cf682f3fcf3c'},properties}}};"
      }
    },
    {
      "id": "upsert",
      "name": "Обновить диспетчер",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1540,
        0
      ],
      "parameters": {
        "method": "={{ $json.method }}",
        "url": "={{ $json.url }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
