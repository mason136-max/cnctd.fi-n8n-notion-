    {
      "id": "calc",
      "name": "Рассчитать и распределить",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        940,
        0
      ],
      "parameters": {
        "jsCode": "const input=$input.all().map(i=>i.json);\nconst days=['Понедельник','Вторник','Среда','Четверг','Пятница','Суббота','Воскресенье'];\nconst now=new Date(); now.setHours(0,0,0,0);\nconst monday=new Date(now); const wd=(now.getDay()+6)%7; monday.setDate(now.getDate()-wd);\nconst dateOf=i=>{const d=new Date(monday);d.setDate(monday.getDate()+i);return d};\nconst stats=input.map(({department,rows})=>{rows=Array.isArray(rows)?rows:[];let open=rows.length,urgent=0,overdue=0,nearest=null,medium=0;for(const p of rows){const pr=p.properties?.['Приоритет']?.select?.name||'';const due=p.properties?.['Дедлайн']?.date?.start;if(pr.includes('Высокий'))urgent++;if(pr==='Средний')medium++;if(due){const d=new Date(due);if(d<now)overdue++;if(!nearest||d<nearest)nearest=d}}const score=open+urgent*3+medium+overdue*5;return{department,open,urgent,overdue,nearest,score}}).filter(x=>x.open>0).sort((a,b)=>b.score-a.score);\nconst buckets=days.map((day,i)=>({day,i,cats:[],score:0,open:0,urgent:0,overdue:0,nearest:null}));\nfor(const s of stats){let allowed=[0,1,2,3,4];if(s.nearest&&s.nearest<dateOf(5)) allowed=allowed.filter(i=>dateOf(i)<=s.nearest);if(!allowed.length&&s.nearest&&s.nearest<dateOf(7))allowed=[5,6].filter(i=>dateOf(i)<=s.nearest);if(!allowed.length)allowed=[0,1,2,3,4];const b=allowed.map(i=>buckets[i]).sort((a,b)=>a.score-b.score||a.i-b.i)[0];b.cats.push(s.department);b.score+=s.score;b.open+=s.open;b.urgent+=s.urgent;b.overdue+=s.overdue;if(s.nearest&&(!b.nearest||s.nearest<b.nearest))b.nearest=s.nearest;}\nreturn buckets.map(b=>{const index=Math.min(100,Math.round(b.score*5));const filled=Math.min(10,Math.ceil(index/10));const level=index<35?'🟢 Низкая':index<70?'🟡 Средняя':'🔴 Высокая';return{json:{day:b.day,order:b.i+1,categories:b.cats,open:b.open,urgent:b.urgent,overdue:b.overdue,nearest:b.nearest?b.nearest.toISOString().slice(0,10):null,index,level,bar:'█'.repeat(filled)+'░'.repeat(10-filled),summary:b.cats.length?b.cats.join(', ')+': '+b.open+' открытых, '+b.overdue+' просроченных':'Нет активных направлений',updated:new Date().toISOString()}}});"
      }
    },
