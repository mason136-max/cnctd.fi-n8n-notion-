    {
      "id": "p",
      "name": "Сформировать план сотрудников",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1000,
        0
      ],
      "parameters": {
        "jsCode": "const all=$input.all().map(x=>x.json);const disp=all.find(x=>x.kind==='dispatcher')?.rows||[];const tasks=Object.fromEntries(all.filter(x=>x.kind==='tasks').map(x=>[x.department,x.rows]));const title=p=>p?.title?.map(x=>x.plain_text).join('')||'';const rich=p=>p?.rich_text?.map(x=>x.plain_text).join('')||'';const dayByCat={};for(const r of disp){const day=title(r.properties?.['День']);for(const c of r.properties?.['Категории']?.multi_select||[])dayByCat[c.name]=day}const now=new Date();const mon=new Date(now);mon.setDate(now.getDate()-((now.getDay()+6)%7));const week=mon.toISOString().slice(0,10);const catMap={'Продукты':'Продукт','Проекты':'Разработка','Команда':'HR / Recruiting','Операционка':'Операционная деятельность'};const dayIndex={'Понедельник':0,'Вторник':1,'Среда':2,'Четверг':3,'Пятница':4,'Суббота':5,'Воскресенье':6};const groups={};for(const [cat,rows] of Object.entries(tasks)){const day=dayByCat[cat];if(!day)continue;for(const r of rows){const p=r.properties||{};const owner=rich(p['Ответственный']).trim()||'Не назначен';const key=[week,day,cat,owner.toLowerCase()].join('|');const g=groups[key]??={key,week,day,category:catMap[cat]||cat,owner,count:0,high:0,titles:[],nearest:null};g.count++;if((p['Приоритет']?.select?.name||'').includes('Высокий'))g.high++;const due=p['Дедлайн']?.date?.start;if(due&&(!g.nearest||due<g.nearest))g.nearest=due;const n=title(p['Задача']);if(n)g.titles.push(n)}}return Object.values(groups).map(g=>{const d=new Date(mon);d.setDate(mon.getDate()+dayIndex[g.day]);g.date=d.toISOString().slice(0,10);g.db=['Суббота','Воскресенье'].includes(g.day)?'e2b4b826-3ac9-4835-bb15-5790acae5b7b':'d9e3f47d-886e-49fa-b109-60e8d57e741b';g.personId=/илья/i.test(g.owner)?'395d872b-594c-81cf-8183-0002356578d3':null;g.priority=g.high?'Высокий':'Средний';g.comment=g.count+' задач. '+g.titles.slice(0,5).join('; ');return{json:g}});"
      }
    },
